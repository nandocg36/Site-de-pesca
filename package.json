{
  "name": "site-de-pesca",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Monorepo: PWA legada (vanilla) + greenfield apps/web + fishing-core + Supabase (Marcos 1–3).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @pesca/web",
    "dev:legacy": "vite --config vite.legacy.config.js",
    "build": "npm run build -w @pesca/web",
    "test": "vitest run -c vitest.config.js",
    "test:core": "npm run test -w @pesca/fishing-core",
    "test:web": "npm run test -w @pesca/web",
    "test:all": "npm run test && npm run test:core && npm run test:web",
    "test:watch": "vitest -c vitest.config.js",
    "e2e:serve": "npm run build -w @pesca/web && npm run preview -w @pesca/web -- --host 127.0.0.1 --port 4173",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "vite": "^6.2.2",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nandocg36/Site-de-pesca.git"
  },
  "bugs": {
    "url": "https://github.com/nandocg36/Site-de-pesca/issues"
  },
  "homepage": "https://github.com/nandocg36/Site-de-pesca#readme",
  "license": "ISC"
}
